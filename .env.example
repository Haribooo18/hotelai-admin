# Supabase project connection (client-safe, exposed to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Fallback tenant used only until every user has `app_metadata.hotel_id` set.
# Keep as the seeded hotel id from supabase/migrations/0001_auth_multitenancy_rls.sql
DEFAULT_HOTEL_ID=hotel_aurora
