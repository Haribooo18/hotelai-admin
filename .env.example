# =============================================================================
# HotelAI Admin — environment variables
# Copy to .env.local for local development:  cp .env.example .env.local
# Production reference: docs/DEPLOYMENT.md
# =============================================================================

# --- Supabase (required) -------------------------------------------------------
# Client-safe values — exposed to the browser via NEXT_PUBLIC_ prefix.
# Find these in Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Required for channel webhooks and Stripe webhook writes.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Tenant fallback (required until all users have hotel_id in JWT) ---------
# Must match a seeded hotel id from supabase/migrations/0001_auth_multitenancy_rls.sql
DEFAULT_HOTEL_ID=hotel_aurora

# --- OpenAI (required for AI receptionist auto-replies) ------------------------
# Server-only. Never prefix with NEXT_PUBLIC_. Leave unset to disable AI provider.
# OPENAI_API_KEY=sk-your-key-here

# --- Telegram (optional — guest messaging channel) -----------------------------
# Server-only. One bot per deployment; scoped to TELEGRAM_HOTEL_ID (falls back to DEFAULT_HOTEL_ID).
# Requires SUPABASE_SERVICE_ROLE_KEY when enabled.
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# TELEGRAM_WEBHOOK_SECRET=random-secret-for-setWebhook
# TELEGRAM_HOTEL_ID=hotel_aurora

# --- Website Chat (optional — SSE widget channel) ------------------------------
# Falls back to DEFAULT_HOTEL_ID. Requires SUPABASE_SERVICE_ROLE_KEY when enabled.
# WEBSITE_CHAT_HOTEL_ID=hotel_aurora

# Comma-free multiline list of allowed embed origins (production required for cross-origin widget).
# Example:
# WEBSITE_WIDGET_ALLOWED_ORIGINS=https://hotel-one.com
# https://hotel-two.com
# https://*.hotelai.app
#
# WEBSITE_WIDGET_ALLOWED_ORIGINS=

# Optional widget hardening (defaults shown)
# WEBSITE_WIDGET_SESSION_RATE_LIMIT=30
# WEBSITE_WIDGET_IP_RATE_LIMIT=60
# WEBSITE_WIDGET_MAX_MESSAGE_LENGTH=4000

# --- Stripe Billing (required for checkout, portal, webhooks) ------------------
# Server-only. Use sk_live_… / whsec_… in production.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...
